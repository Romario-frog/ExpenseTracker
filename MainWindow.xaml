<Window x:Class="ExpenseTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Трекер витрат" Height="620" Width="900"
        WindowStartupLocation="CenterScreen"
        MinHeight="520" MinWidth="760">
    <Grid Background="#F4F6F8" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="14" Padding="18" Margin="0 0 0 14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Трекер витрат" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="Додавай доходи та витрати, а програма порахує баланс." Foreground="#667085" Margin="0 4 0 0" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Поточний баланс" Foreground="#667085" HorizontalAlignment="Right" />
                    <TextBlock x:Name="BalanceText" Text="0.00 грн" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16" Margin="0 0 0 14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0 0 10 0">
                    <TextBlock Text="Тип" FontWeight="SemiBold" Margin="0 0 0 6" />
                    <ComboBox x:Name="TypeBox" Height="34" SelectedIndex="0">
                        <ComboBoxItem Content="Витрата" />
                        <ComboBoxItem Content="Дохід" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0 0 10 0">
                    <TextBlock Text="Категорія" FontWeight="SemiBold" Margin="0 0 0 6" />
                    <ComboBox x:Name="CategoryBox" Height="34" SelectedIndex="0">
                        <ComboBoxItem Content="Їжа" />
                        <ComboBoxItem Content="Транспорт" />
                        <ComboBoxItem Content="Навчання" />
                        <ComboBoxItem Content="Розваги" />
                        <ComboBoxItem Content="Зарплата" />
                        <ComboBoxItem Content="Інше" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0 0 10 0">
                    <TextBlock Text="Сума" FontWeight="SemiBold" Margin="0 0 0 6" />
                    <TextBox x:Name="AmountBox" Height="34" VerticalContentAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0 0 10 0">
                    <TextBlock Text="Коментар" FontWeight="SemiBold" Margin="0 0 0 6" />
                    <TextBox x:Name="CommentBox" Height="34" VerticalContentAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="4" Content="Додати" Height="38" Margin="0 22 0 0"
                        Background="#2563EB" Foreground="White" FontWeight="Bold"
                        Click="AddButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="14" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Історія операцій" FontSize="20" FontWeight="Bold" Margin="0 0 0 12" />

                <DataGrid x:Name="TransactionsGrid" Grid.Row="1" AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy HH:mm}" Width="150" />
                        <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100" />
                        <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="130" />
                        <DataGridTextColumn Header="Сума" Binding="{Binding AmountText}" Width="120" />
                        <DataGridTextColumn Header="Коментар" Binding="{Binding Comment}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 12 0 0">
                    <Button Content="Видалити вибране" Width="150" Height="34" Margin="0 0 10 0" Click="DeleteButton_Click" />
                    <Button Content="Очистити все" Width="120" Height="34" Click="ClearButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
